{
  "name": "pi-mempalace",
  "version": "0.7.0",
  "type": "module",
  "description": "Persistent agent memory for pi — raw verbatim storage with semantic search. Fork (Jabbslad lineage) with importance-blended retrieval ranking, per-prompt auto-recall, safe bulk-prune + standalone CLI (MEMPALACE_HOME-relocatable, no pi required).",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shashank-mugiwara/pi-mempalace.git"
  },
  "fork": {
    "upstream": "https://github.com/Jabbslad/pi-mempalace",
    "upstreamVersion": "0.2.0",
    "maintainer": "shashank-mugiwara"
  },
  "files": [
    "extensions/",
    "skills/",
    "cli/",
    "README.md"
  ],
  "engines": {
    "node": ">=22.18"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "skills": [
      "./skills"
    ]
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "better-sqlite3": "^11.9.1",
    "sqlite-vec": "^0.1.6"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "typescript": "^6.0.2"
  }
}
